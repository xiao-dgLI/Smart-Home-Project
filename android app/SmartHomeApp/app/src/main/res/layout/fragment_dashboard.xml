<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题 + 更新 + 添加按钮 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="环境监测"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_centerVertical="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddSensor"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="+ 添加"
                android:textSize="13sp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- ★ 更新按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRefreshCloud"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="更新"
                android:textSize="13sp"
                android:layout_toStartOf="@id/btnAddSensor"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </RelativeLayout>

        <!-- 连接状态 -->
        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="未连接"
            android:textColor="#F44336"
            android:textSize="14sp"
            android:padding="8dp"
            android:background="#FFEBEE"
            android:layout_marginBottom="16dp" />

        <!-- 传感器卡片列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSensorCards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="4dp" />

        <!-- 空状态提示 -->
        <TextView
            android:id="@+id/tvEmptyHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="暂无传感器，点击上方 \+ 添加\ 按钮添加"
            android:textSize="14sp"
            android:textColor="#9E9E9E"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone" />

        <!-- 发送指令 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="发送指令"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/etSendCmd"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="输入指令..."
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:background="@android:drawable/editbox_background"
                android:inputType="text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendCmd"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="发送"
                android:textSize="13sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- 通信日志 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="通信日志"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.smarthome.app.view.TouchScrollView
            android:id="@+id/scrollLogs"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@android:color/white"
            android:padding="12dp"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <TextView
                android:id="@+id/tvLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#333333"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:text="等待连接..."
                android:lineSpacingExtra="2dp" />

        </com.smarthome.app.view.TouchScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="清空日志"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>