<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRule"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- 同步状态指示点 -->
        <View
            android:id="@+id/viewSyncDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_dot"
            android:layout_marginEnd="12dp" />

        <!-- 名称和描述 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRuleName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="规则名称"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121" />

            <TextView
                android:id="@+id/tvRuleDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="规则描述"
                android:textSize="13sp"
                android:textColor="#757575"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvSyncInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#BDBDBD"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <Switch
            android:id="@+id/switchRule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnDeleteRule"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="删除" />

    </LinearLayout>
</androidx.cardview.widget.CardView>